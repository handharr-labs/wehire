# ─────────────────────────────────────────
# Google Apps Script (required)
# ─────────────────────────────────────────
# Deploy your Apps Script as a Web App and paste the URL here.
# How to obtain:
#   1. Open your Apps Script project → Deploy → New deployment
#   2. Type: Web App, Execute as: Me, Who has access: Anyone
#   3. Copy the deployment URL
NEXT_PUBLIC_APPS_SCRIPT_URL=

# ─────────────────────────────────────────
# Subdomain routing (required for production, optional in dev)
# ─────────────────────────────────────────
# The root domain used to resolve company subdomains.
# e.g., if set to "wehire.app", then "acme.wehire.app" routes to company "acme".
# In local dev you can leave this blank or set it to "localhost".
NEXT_PUBLIC_BASE_DOMAIN=wehire.app
